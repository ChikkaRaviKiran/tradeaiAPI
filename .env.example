# ═══════════════════════════════════════════════════════════════
# REQUIRED — AngelOne SmartAPI (get from https://smartapi.angelone.in/)
# ═══════════════════════════════════════════════════════════════
ANGELONE_API_KEY=your_api_key_here
ANGELONE_CLIENT_ID=your_client_id
ANGELONE_PASSWORD=your_password
ANGELONE_MPIN=your_4digit_mpin
ANGELONE_TOTP_SECRET=your_totp_secret

# ═══════════════════════════════════════════════════════════════
# REQUIRED — Database (defaults work with docker-compose)
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tradeai
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════
# REQUIRED — OpenAI (for AI Decision Engine)
# ═══════════════════════════════════════════════════════════════
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ═══════════════════════════════════════════════════════════════
# OPTIONAL — Telegram Alerts (leave blank to skip)
# ═══════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════════
# OPTIONAL — Telegram News Channel (for pre-market intelligence)
# ═══════════════════════════════════════════════════════════════
TELEGRAM_NEWS_CHANNEL=daytradertelugu

# ═══════════════════════════════════════════════════════════════
# OPTIONAL — Email Alerts (leave blank to skip)
# ═══════════════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ═══════════════════════════════════════════════════════════════
# Trading Config
# ═══════════════════════════════════════════════════════════════
INITIAL_CAPITAL=100000
MAX_TRADES_PER_DAY=3
MAX_DAILY_LOSS_PCT=2.0
CONSECUTIVE_LOSS_LIMIT=3
NIFTY_LOT_SIZE=65
ACTIVE_INSTRUMENTS=NIFTY,SENSEX
MAX_CONCURRENT_POSITIONS=2
MAX_CONCURRENT_PER_INSTRUMENT=1
RISK_PER_TRADE_PCT=1.0
MAX_SPREAD_PCT=3.0

# ═══════════════════════════════════════════════════════════════
# System
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
PAPER_TRADING=true
